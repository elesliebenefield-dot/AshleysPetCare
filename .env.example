# Required for inquiry form email delivery (Resend - free tier)
# Get your API key at https://resend.com
RESEND_API_KEY=re_your_api_key_here

# Ashley's email address — where inquiry form submissions are sent
CONTACT_EMAIL=ashley@yourdomain.com

# Sender address shown in the From field of inquiry emails
# Free tier default (testing only, sends to verified emails only): onboarding@resend.dev
# Production: use a verified domain, e.g. noreply@ashleyspetcare.com
RESEND_FROM_EMAIL=onboarding@resend.dev
